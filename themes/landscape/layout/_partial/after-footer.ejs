<%- js('js/scripts.js') %>
<%- js('js/dist/qr-code-styling.js') %>
<%- js('js/dist/tinycolor-min.js') %>
<%- json({
  src: 'js/dist/qr-code-styling-options-contact-light.json',
  id: 'qr-code-styling-options-light'
}) %>
<%- json({
  src: 'js/dist/qr-code-styling-options-contact-dark.json',
  id: 'qr-code-styling-options-dark'
}) %>

<script>
  //--- eval url hash on load
  var hash = window.location.hash.substr(1);
  switch (hash.toLowerCase()) {
    case "contact":
      window.addEventListener('load', function () {
        dialog.contact();
      });
      break;
    case "continue":
      //has no offset due to fixed header
      //...document.getElementById("more").scrollIntoView({ behavior: "smooth", block: "start", inline: "nearest"});
      window.scrollTo({
        behavior: 'smooth',
        top:
          document.querySelector("#more").getBoundingClientRect().top -
          document.body.getBoundingClientRect().top -
          200,
      });
      history.replaceState(null, null, ' '); // remove hash
    default: break;
  }
</script>

<script>
  /*** EVENTS */

  window.addEventListener('scroll', function() {
    scrollHeader();
    initBackTop();
    initViewportVisibility();
  }, { passive: true });

  window.addEventListener('resize', function() {
    initHeader();
    initViewportVisibility();
  });

  /*** INITS */
  // $(document).ready(function() {
  initHeader();
  initScrollProgress();
  // });
  initViewportVisibility();
  initNavMenuScroll();
  ensureIconLinkText();

  // MENU-ITEM-SCROLL
  let path = window.location.pathname.split('/');
  let pathItem = path[1].toLowerCase();
  if (["archives","post"].includes(pathItem)) pathItem = "articles"; //HACK
  //console.log(window.location.pathname + " ... " + path.length);
  setTimeout(() => {
    let e = document.getElementById(`nav-${pathItem}-link`);
    if (!e && path.length > 2) e = document.getElementById("nav-slashes-link"); //HACK
    //console.log(e);
    if (e) e.scrollIntoView({ behavior: "smooth", block: "center", inline: "center" });
  }, 250);

  // AUTOTYPING
  $("#title-wrap").empty();
  new AutoTyping({
    id: 'title-wrap',
    typeText: ['<%= config.title %>'],
    textColor: window.getComputedStyle(document.documentElement).getPropertyValue('--color-logo'),
    typeSpeed: 100,
    typeDelay: 200,
    showCursor: false,
    delete: false,
    typeInfinity: false
  }).init();

  //MEDIUM-ZOOM
  mediumZoom(document.querySelectorAll('img.zoom'), {
    background: window.getComputedStyle(document.documentElement).getPropertyValue('--color-backdrop'),
    margin: 20,
    scrollOffset: 10
  });

</script>

