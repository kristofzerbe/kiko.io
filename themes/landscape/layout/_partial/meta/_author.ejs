{
  "@type": "Person",
  "@id": "<%= config.url %>/#person",
  "name": "<%= config.author %>",
  "url": "<%= config.url %>/about",
  "image": "<%= config.url %><%= config.avatar %>", 
  "sameAs": [
  <% Object.entries(config.profiles).forEach(([key, value], idx, arr) => { %>
    "<%= value %>"<%= (idx === arr.length - 1) ? "" : "," %>
  <% }) %>
  ]
}