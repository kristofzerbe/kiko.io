<% if (page.photograph){ %>
  <%- partial('_partial/photograph') %>
<% } %>

<script>
  var body = document.getElementById("body");
  body.classList.add("note-view");
</script>

<article id="note-<%= page.slug %>" data-pagefind-meta="type:Note"
         class="article note h-entry <%= (page.rel?.verb) && "rel" %>">

  <div class="article-meta" data-pagefind-ignore>
    <%- partial('_partial/post/author') %>
    <div class="article-category p-category category-note">
      <a class="article-category-link" href="/notes/<%- page.year %>">Note</a> 
    </div>
    <time class="published dt-published" data-pagefind-meta="date" 
          datetime="<%= date_xml(page.date) %>"><%= date(page.date, 'DD MMM YYYY') %></time>
    <% if (page.rel?.verb) { %>
      <small>
        <span><%= page.rel.verb.replaceAll("-", " ") %></span>
        <a href="<%= page.rel.url %>" class="u-<%= page.rel.verb %>" title="<%= page.rel.caption %>"><%= page.rel.caption %></a>
      </small>
    <% } %>
  </div>
    
  <div class="article-inner">

    <header class="article-header">
      <%- partial('_partial/post/title', { post: page, class_name: 'article-title p-name', show_link: false, index: false }) %>
      <div id="interactions-totalnumber-placeholder"></div>
    </header>

    <div class="article-entry e-content">
      <%- page.content %>
    </div>
  
    <footer class="article-footer" data-pagefind-ignore>
      <%- partial('_partial/post/permalink', { post: page }) %>
    </footer>
  
  </div>
  <%- partial('_partial/post/share') %>

  <%- partial('_partial/post/interaction', { post: page, type: 'note', comments: false  }) %>

</article>
