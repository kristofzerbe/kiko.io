<%_
  const updated = (item) => {
    let pub = moment(item.date).toISOString();
    let upd = moment(item.updated).toISOString();
    return (pub === upd) ? null : upd;
  }
  const imageSource = (item) => {
    if (item.photograph) {
      if (item.photograph.socialmedia) {
        return config.url + item.photograph.socialmedia.replace("/static", "")
      } else {
        return config.url + "/photos/mobile/" + item.photograph.file;
      }
    }
  }
  const profileList = Object.entries(config.profiles).map(([key, value]) => ({
    href: value,
    rel: (['mastodon', 'github', 'linkedin'].includes(key.toLowerCase())) ? key.toLowerCase() : "me"
  }));
_%>

<%- JSON.stringify({
  version: 'https://jsonfeed.org/version/1.1',
  title: config.title + " Posts",
  description: config.description,
  home_page_url: config.url,
  feed_url: config.url + "/" + output,
  language: "en-US",
  icon: config.url + "/" + config.feed.logo,
  favicon: config.url + "/" + config.feed.icon,
  authors: [{
    name: config.author,
    url: config.url,
    avatar: config.url + config.avatar
  }],
  _byline: {
    version: "https://bylinespec.org/1.0",
    contributors: [{
      id: config.author_id,
      name: config.author,
      url: config.url,
      avatar: config.url + config.avatar,
      profiles: profileList,
      uses: config.url + "/uses",
      theme: {
        style: "light"
      }
    }]
  },
  items: items.map(item => ({
    id: item.permalink,
    url: item.permalink,
    title: item.title,
    image: imageSource(item),
    date_published: moment(item.date).toISOString(),
    date_modified: updated(item),
    content_html: item.content || '',
    _byline: {
      author: config.author_id,
      perspective: "personal"
    },
    tags: (item.tags ? item.tags.toArray() : []).map(({ name }) => name)
  }))
}, null, 4) _%>
